# API (Express) — must match app/lib/common/api_config.dart default port.
PORT=3003

# Base URL for portfolio links in API responses (default: http://localhost:{PORT}).
# Use http://YOUR_LAN_IP:3003 for phones on Wi‑Fi, or http://10.0.2.2:3003 for Android emulator browser.
#PUBLIC_BASE_URL=http://localhost:3003

# MongoDB — use Atlas in production. Copy from Atlas → Connect → Drivers (SRV or standard).
# Always include the database name before "?": …/careerpath?…
# Replace USER and PASSWORD; URL-encode special characters in the password (@ # / etc.).
# Paste your full URI from Atlas (include /careerpath before ?). Do not commit real credentials.
MONGODB_URI=

JWT_SECRET=change-this-to-a-long-random-string-in-production

# Local FastAPI ATS rule engine (Python service)
# Start it from: ../Junior_code/ats-rule-engine copy
ATS_FASTAPI_URL=http://127.0.0.1:8000
ATS_FASTAPI_TIMEOUT_MS=20000
